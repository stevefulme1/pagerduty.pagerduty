---
# PagerDuty EDA Rulebook
# Generated by pagerduty.pagerduty.eda_setup role
# Do not edit manually - changes will be overwritten

- name: PagerDuty Event-Driven Automation
  hosts: all
  sources:
    - ansible.eda.webhook:
        host: "{{ eda_webhook_host }}"
        port: {{ eda_webhook_port }}
{% if eda_webhook_secret | default('') | length > 0 %}
        hmac_secret: "{{ eda_webhook_secret }}"
        hmac_algo: sha256
        hmac_header: X-PagerDuty-Signature
{% endif %}

  rules:
    # --- Incident Triggered ---
    - name: Handle PagerDuty incident triggered
      condition: event.payload.event.event_type == "incident.triggered"
      actions:
        - debug:
            msg: >-
              PagerDuty incident triggered:
              {{ '{{' }} event.payload.event.data.title {{ '}}' }}
              ({{ '{{' }} event.payload.event.data.id {{ '}}' }})
{% for mapping in remediation_playbooks %}

    - name: "Remediate {{ mapping.service_name }} incident"
      condition: >-
        event.payload.event.event_type == "incident.triggered" and
        event.payload.event.data.service.name == "{{ mapping.service_name }}"
      actions:
        - run_playbook:
            name: "{{ mapping.playbook_path }}"
            extra_vars:
              incident_id: "{{ '{{' }} event.payload.event.data.id {{ '}}' }}"
              service_name: "{{ '{{' }} event.payload.event.data.service.name {{ '}}' }}"
              incident_title: "{{ '{{' }} event.payload.event.data.title {{ '}}' }}"
              incident_urgency: "{{ '{{' }} event.payload.event.data.urgency {{ '}}' }}"
{% endfor %}

    # --- Incident Acknowledged ---
    - name: Handle PagerDuty incident acknowledged
      condition: event.payload.event.event_type == "incident.acknowledged"
      actions:
        - debug:
            msg: >-
              PagerDuty incident acknowledged:
              {{ '{{' }} event.payload.event.data.title {{ '}}' }}
              by {{ '{{' }} event.payload.event.data.acknowledgers[0].summary | default("unknown") {{ '}}' }}

    # --- Incident Resolved ---
    - name: Handle PagerDuty incident resolved
      condition: event.payload.event.event_type == "incident.resolved"
      actions:
        - debug:
            msg: >-
              PagerDuty incident resolved:
              {{ '{{' }} event.payload.event.data.title {{ '}}' }}

    # --- Incident Escalated ---
    - name: Handle PagerDuty incident escalated
      condition: event.payload.event.event_type == "incident.escalated"
      actions:
        - debug:
            msg: >-
              PagerDuty incident escalated:
              {{ '{{' }} event.payload.event.data.title {{ '}}' }}
              to {{ '{{' }} event.payload.event.data.escalation_policy.summary | default("unknown") {{ '}}' }}
